# Production template.
# Copy to `.env` on the server and fill in values. Do not commit secrets.
# https://craftcms.com/docs/5.x/configure.html

# Application ID (optional; uniquely scopes session/cache/mutex data)
CRAFT_APP_ID=

# Environment Craft is running in
CRAFT_ENVIRONMENT=production

# Database connection settings
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=127.0.0.1
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=
CRAFT_DB_USER=
CRAFT_DB_PASSWORD=
CRAFT_DB_TABLE_PREFIX=

# Site URL and web root (docroot is `web/` at the app root)
PRIMARY_SITE_URL="https://www.dbtsearch.org"
CRAFT_WEB_ROOT="/home/master/applications/dbtsearch/public_html/web"

# General settings (CRAFT_* maps automatically to general config)
# Generate a key: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=false
CRAFT_ALLOW_ADMIN_CHANGES=false
CRAFT_DISALLOW_ROBOTS=false

# Provider session duration (seconds). 31536000 = 1 year.
CRAFT_USER_SESSION_DURATION=31536000
CRAFT_REMEMBERED_USER_SESSION_DURATION=31536000
CRAFT_PURGE_STALE_USER_SESSION_DURATION=31536000

# Email (Resend — see config/project/project.yaml)
# RESEND_API_KEY=
