# Copy this file to .env and fill in your values.
# Do not commit .env (it is in .gitignore).

# Required: long random string for session signing (min 8 characters).
# Generate one at https://passwordsgenerator.net
SERVER_SESSION_SECRET=your-random-secret-here

# --- DDEV (PostgreSQL only): use this when running DDEV for the database ---
# After `ddev start`, use this so the Node app (running on your host) connects to DDEV's Postgres.
# Port 55432 is set in .ddev/config.yaml (host_db_port).
# DATABASE_URL=postgresql://db:db@127.0.0.1:55432/db

# --- Non-DDEV local: leave DATABASE_URL unset ---
# pool.js will use host localhost, port 5432, database dbtsearch.

# --- Production: set DATABASE_URL to your deployed Postgres ---
# DATABASE_URL=postgresql://user:password@host:5432/dbtsearch

# --- Optional: Linear API (for scripts/linear.js — close/create issues) ---
# LINEAR_API_KEY=lin_api_...
