# Read about configuration:
# https://craftcms.com/docs/5.x/configure.html
#
# Copy to `.env` and fill in values. Do not commit `.env`.
# For environment-specific templates see:
#   .env.example.dev | .env.example.staging | .env.example.production

# Application ID (optional; uniquely scopes session/cache/mutex data)
CRAFT_APP_ID=

# Environment Craft is running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# Database connection settings
# With DDEV, Craft runs in the web container — use host `db` (the database service name).
# For host-side CLI without `ddev craft`, use 127.0.0.1 and the DB port from `ddev describe`.
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=db
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=craft
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db

# Site URL (used by project config for site base URL and asset URLs)
PRIMARY_SITE_URL=https://dbtsearch.ddev.site

# Absolute path to the web root (used by the assets volume: $CRAFT_WEB_ROOT/uploads).
# DDEV web container path; adjust when deploying outside DDEV.
CRAFT_WEB_ROOT=/var/www/html/web

# General settings (CRAFT_* maps automatically to general config)
# Generate a key: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true

# Provider session duration (seconds). 31536000 = 1 year.
CRAFT_USER_SESSION_DURATION=31536000
CRAFT_REMEMBERED_USER_SESSION_DURATION=31536000
CRAFT_PURGE_STALE_USER_SESSION_DURATION=31536000

# Email (Resend — see config/project/project.yaml)
# RESEND_API_KEY=
