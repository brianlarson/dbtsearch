# Craft uses MySQL 8 (extra service); DDEV primary db stays Postgres for legacy.
# Applied by post-start hook so Craft never uses Postgres.
CRAFT_DB_DRIVER="mysql"
CRAFT_DB_SERVER="mysql8"
CRAFT_DB_PORT="3306"
CRAFT_DB_DATABASE="craft"
CRAFT_DB_USER="craft"
CRAFT_DB_PASSWORD="craft"
PRIMARY_SITE_URL="https://dbtsearch.ddev.site"
CRAFT_WEB_ROOT="/var/www/html/cms/web"
