#!/usr/bin/env bash
## Description: Import a MySQL dump into Craft's database (craft on primary MySQL)
## Usage: craft-db-import [path-to.sql|.sql.gz]
## Example: ddev craft-db-import storage/backups/latest.sql.gz
## Example: ddev craft-db-import
set -e

FILE="${1:-storage/backups/latest.sql.gz}"
APP_ROOT="${DDEV_APPROOT:-.}"
FULL_PATH="${APP_ROOT}/${FILE}"

if [[ ! -f "${FULL_PATH}" ]]; then
  echo "SQL file not found: ${FULL_PATH}" >&2
  echo "Usage: ddev craft-db-import [path-to.sql|.sql.gz]" >&2
  echo "Default: storage/backups/latest.sql.gz" >&2
  exit 1
fi

if [[ "${FILE}" == *.gz ]]; then
  gunzip -c "${FULL_PATH}" | ddev mysql craft
else
  ddev mysql craft < "${FULL_PATH}"
fi
echo "Craft database imported into craft (MySQL 8.0)."
