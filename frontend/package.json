{
  "name": "dbtsearch-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build:splash": "vite build --config vite.splash.config.js",
    "build:directory": "vite build --config vite.directory.config.js",
    "verify:directory-css": "vite build --config vite.directory.config.js && git diff --quiet ../web/css/directory.css ../web/css/directory.min.js || (echo 'Template classes changed: commit web/css/directory.css and directory.min.js after npm run build:directory' >&2 && exit 1)",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "preline": "^4.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/html": "^8.4.7",
    "@storybook/html-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/vite": "^4.0.0",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.0.0"
  }
}
