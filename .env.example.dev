# Local / DDEV development template.
# Copy to `.env` and fill in values. Do not commit `.env`.
# https://craftcms.com/docs/5.x/configure.html

# Application ID (optional; uniquely scopes session/cache/mutex data)
CRAFT_APP_ID=

# Environment Craft is running in
CRAFT_ENVIRONMENT=dev

# Database — DDEV sets these in the web container via `.ddev/craft-mysql.env.web`
# (copied to `.ddev/.env.web` on `ddev start`) and `web_environment` in `.ddev/config.yaml`.
# Do not set CRAFT_DB_* here when using DDEV: dotenv would override the container values.
# Host-side CLI only (not `ddev craft`):
# CRAFT_DB_DRIVER=mysql
# CRAFT_DB_SERVER=127.0.0.1
# CRAFT_DB_PORT=3306
# CRAFT_DB_DATABASE=craft
# CRAFT_DB_USER=craft
# CRAFT_DB_PASSWORD=craft

# Site URL (used by project config for site base URL and asset URLs)
PRIMARY_SITE_URL=https://dbtsearch.ddev.site

# Absolute path to the web root (used by the assets volume: $CRAFT_WEB_ROOT/uploads).
# DDEV sets CRAFT_WEB_ROOT=/var/www/html/web in the web container — omit here so it is not overridden.
# CRAFT_WEB_ROOT=

# General settings (CRAFT_* maps automatically to general config)
# Generate a key: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true

# Email (Resend — see config/project/project.yaml)
# RESEND_API_KEY=
