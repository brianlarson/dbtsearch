# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# Database (DDEV: .env.web sets these in the container; here for host-side CLI / when .env is the only source)
# In DDEV web container, CRAFT_DB_SERVER=mysql8 is set by .env.web and is not overwritten by this file.
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=127.0.0.1
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=craft
CRAFT_DB_USER=craft
CRAFT_DB_PASSWORD=craft

# Optional: SMTP (e.g. Gmail). When MAIL_HOST is set, Craft uses SMTP instead of project default.
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password

# General settings
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true
