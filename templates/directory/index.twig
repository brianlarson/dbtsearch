{% set searchTerm = craft.app.request.getQueryParam('q') ?? '' %}
{% set onlyAvailable = craft.app.request.getQueryParam('availability') == '1' %}
{% set pageHeading = 'Providers' %}
{% set pageSubheading = 'DBT Providers in Minnesota' %}
{% set heroImageUrl = '/images/pexels-hero-1440.webp' %}

{% set providersQuery = craft.entries()
  .section('providers')
  .status(null)
  .with(['locations', 'logo'])
  .limit(500)
  .orderBy('title asc') %}

{% if searchTerm %}
  {% set providersQuery = providersQuery.search(searchTerm ~ '*') %}
{% endif %}

{% set providerEntries = providersQuery.all() %}
{% set providers = [] %}

{% for provider in providerEntries %}
  {% set locations = provider.locations.all() %}
  {% set hasAvailability = false %}
  {% for location in locations %}
    {% if location.availability %}
      {% set hasAvailability = true %}
    {% endif %}
  {% endfor %}
  {% if not onlyAvailable or hasAvailability %}
    {% set providers = providers|merge([{
      provider: provider,
      locations: locations,
      hasAvailability: hasAvailability
    }]) %}
  {% endif %}
{% endfor %}

<!DOCTYPE html>
<html lang="{{ craft.app.language }}" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Directory | {{ siteName ?? 'DBT Search' }}</title>
  <link rel="stylesheet" href="{{ url('/css/splash.css') }}" />
</head>
<body class="dark min-h-screen bg-background text-foreground font-sans antialiased" data-theme="dbtsearch">
  <header class="sticky top-0 z-[1030] border-b border-slate-800 bg-slate-950/95 backdrop-blur supports-[backdrop-filter]:bg-slate-950/80">
    <div class="mx-auto flex max-w-6xl items-center gap-2 px-4 py-2 sm:px-6 lg:px-8">
      <a href="{{ url('/') }}" class="inline-flex shrink-0 items-center py-1 md:py-2 xl:py-1">
        <img src="{{ url('/uploads/dbtsearch-logo.svg') }}" alt="DBT Search" class="h-auto max-w-[170px] md:hidden" width="170" height="40" />
        <img src="{{ url('/uploads/dbtsearch-logo.svg') }}" alt="DBT Search" class="hidden h-auto max-w-[280px] md:block" width="280" height="48" />
      </a>
      <nav class="hidden flex-1 items-center justify-center gap-1 md:flex lg:gap-2" aria-label="Primary">
        <a href="{{ url('directory') }}" class="rounded-md bg-slate-800/80 px-3 py-2 text-sm font-medium text-white" aria-current="page">Providers</a>
        <a href="{{ url('about') }}" class="rounded-md px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800/60 hover:text-white">About</a>
        <a href="{{ url('faqs') }}" class="rounded-md px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800/60 hover:text-white">FAQs</a>
      </nav>
      <div class="ml-auto flex items-center gap-1 sm:gap-2">
        <a href="{{ url('contact') }}" class="hidden rounded-md border border-slate-600 px-3 py-2 text-sm font-medium text-slate-200 hover:border-slate-500 hover:bg-slate-800/50 hover:text-white md:inline-flex">Contact</a>
        <a href="{{ url('login') }}" class="inline-flex items-center rounded-md bg-slate-600 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-500">Login</a>
      </div>
    </div>
  </header>

  <section class="relative min-h-[7rem] bg-slate-900 py-5 md:min-h-[9rem]">
    <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6 lg:px-8"></div>
    <div class="absolute inset-0 grid grid-cols-1 md:grid-cols-2">
      <div class="hidden md:block"></div>
      <div class="relative" aria-hidden="true">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ heroImageUrl }}');"></div>
      </div>
    </div>
    <div class="absolute inset-0 bg-black/50 md:hidden" aria-hidden="true"></div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-6 sm:px-6 md:py-8 lg:px-8">
    <div class="grid grid-cols-1 items-end gap-2 md:grid-cols-2 md:gap-4">
      <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{{ pageHeading }}</h1>
      <h2 class="text-base font-medium text-slate-400 md:text-right">{{ pageSubheading }}</h2>
    </div>
    <hr class="mt-4 border-slate-700" />
  </section>

  <main class="mx-auto mb-2 max-w-6xl px-4 sm:px-6 lg:mb-4 lg:px-8 xl:mb-5">
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 md:p-5">
      <div class="mb-3 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <label for="availability-input" class="flex cursor-pointer items-start gap-3 pb-1 text-sm text-slate-300 md:items-center">
          <input id="availability-input" form="directory-filters" type="checkbox" name="availability" value="1" {% if onlyAvailable %}checked{% endif %} class="peer sr-only" />
          <span class="relative mt-0.5 inline-block h-7 w-12 shrink-0 rounded-full border border-slate-600 bg-slate-700 transition-colors peer-checked:border-primary/50 peer-checked:bg-primary/35 after:pointer-events-none after:absolute after:left-0.5 after:top-0.5 after:h-6 after:w-6 after:rounded-full after:bg-white after:shadow after:transition-transform after:duration-200 after:ease-out peer-checked:after:translate-x-[1.25rem] md:mt-0" aria-hidden="true"></span>
          <span class="ms-0.5 leading-snug">Only show providers with availability</span>
        </label>
        <div class="text-sm text-slate-400">Results: {{ providers|length }}</div>
      </div>

      <form id="directory-filters" method="get" action="{{ url('directory') }}" class="grid gap-3">
      <div>
        <label for="directory-q" class="mb-1 block text-sm font-medium text-slate-200">Search by provider name</label>
        <input
          id="directory-q"
          type="search"
          name="q"
          value="{{ searchTerm }}"
          placeholder="Start typing a provider name..."
          class="w-full rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-white placeholder-slate-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        />
      </div>
        <div>
          <button type="submit" class="inline-flex rounded-lg bg-primary px-4 py-2 font-semibold text-primary-foreground hover:opacity-90">Apply filters</button>
        </div>
      </form>
    </div>

    {% if providers is empty %}
      <section class="mt-6 rounded-xl border border-layer-line bg-layer p-6 text-center">
        <p class="mb-4 text-sm text-muted-foreground">No providers match your current filters.</p>
        <a href="{{ url('directory') }}" class="inline-flex rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90">Reset filters</a>
      </section>
    {% else %}
      <ul class="mt-6 list-none space-y-[2.5rem] p-0">
        {% for item in providers %}
          {% set provider = item.provider %}
          {% set primaryLocation = item.locations|first %}
          {% set logo = provider.logo.one() ?? null %}
          {% set providerPhone = (attribute(provider, 'phone') ?? attribute(primaryLocation, 'phone') ?? '') %}
          {% set providerEmail = (attribute(provider, 'email') ?? attribute(primaryLocation, 'email') ?? '') %}
          {% set websiteField = attribute(provider, 'website') ?? attribute(provider, 'urlField') ?? null %}
          {% set websiteUrl = '' %}
          {% if websiteField %}
            {% if websiteField.url is defined and websiteField.url %}
              {% set websiteUrl = websiteField.url %}
            {% elseif websiteField.value is defined and websiteField.value %}
              {% set websiteUrl = websiteField.value %}
            {% else %}
              {% set websiteUrl = websiteField %}
            {% endif %}
          {% elseif attribute(primaryLocation, 'website') %}
            {% set websiteUrl = attribute(primaryLocation, 'website') %}
          {% endif %}
          <li>
            <article class="w-full overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
              <div class="grid grid-cols-1 sm:grid-cols-12">
                <div class="overflow-hidden rounded-t-xl pb-2 sm:col-span-4 sm:rounded-l-xl sm:rounded-tr-none sm:pb-0 sm:pr-3 md:col-span-3">
                  <div class="relative flex min-h-[174px] w-full items-center justify-center p-[2.25rem] {{ logo ? 'bg-white' : 'bg-slate-800/60' }}">
                    {% if logo %}
                      <img src="{{ logo.url }}" alt="{{ provider.title }} logo" class="max-h-full max-w-full object-contain" />
                    {% else %}
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-10 w-10 text-brand" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                      </svg>
                    {% endif %}
                  </div>
                </div>
                <div class="self-center sm:col-span-8 md:col-span-9">
                  <div class="flex flex-col gap-6 p-4 sm:flex-row sm:justify-between sm:gap-4 sm:py-10 sm:pl-3 sm:pr-4 md:pl-6 md:pr-12">
                    <div class="relative min-w-0 pe-2 sm:pe-4">
                      <div class="mb-4 flex flex-wrap gap-2">
                  <span class="rounded border px-2 py-0.5 text-xs font-medium {{ item.hasAvailability ? 'border-emerald-500/70 text-emerald-300' : 'border-slate-500 text-slate-400' }}">
                    {{ item.hasAvailability ? 'Availability' : 'No Availability' }}
                  </span>
                        {% if provider.dbtaCertified %}
                          <span class="rounded border border-sky-500/60 px-2 py-0.5 text-xs font-medium text-sky-300">DBT-A Certified</span>
                        {% endif %}
                      </div>
                      <h2 class="mb-1 text-xl font-semibold leading-tight text-brand sm:text-2xl">{{ provider.title }}</h2>
                      {% if primaryLocation %}
                        <p class="mb-3 text-sm leading-relaxed text-slate-300">
                          {{ primaryLocation.title }}{% if primaryLocation.city %} {{ primaryLocation.city }}{% endif %}{% if primaryLocation.state %}, {{ primaryLocation.state }}{% endif %} {{ primaryLocation.zip }}
                        </p>
                      {% endif %}
                      {% if providerPhone %}
                        <div class="mb-0 text-base">
                          <a href="tel:{{ providerPhone|replace({' ': '', '-': '', '(': '', ')': ''}) }}" class="text-brand no-underline hover:underline">{{ providerPhone }}</a>
                        </div>
                      {% endif %}
                    </div>
                    <div class="flex shrink-0 flex-col items-start gap-3 sm:items-end">
                      <div class="text-right text-slate-500">
                        <span class="text-xs">Last updated</span><br />
                        <span class="text-sm font-semibold text-sky-400">{{ provider.dateUpdated ? provider.dateUpdated|date('M j, Y') : 'Unknown' }}</span>
                      </div>
                      <div class="flex flex-col gap-3 sm:items-end">
                        {% if websiteUrl %}
                          <a href="{{ websiteUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-lg border border-slate-600 px-3 py-2 text-sm text-slate-200 hover:border-primary/50 hover:text-white">Website</a>
                        {% endif %}
                        {% if providerEmail %}
                          <a href="mailto:{{ providerEmail }}?subject=Inquiry%20from%20DBTsearch.org" class="inline-flex items-center rounded-lg border border-slate-600 px-3 py-2 text-sm text-slate-200 hover:border-primary/50 hover:text-white">Email</a>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </main>

  <footer class="mt-14 border-t border-slate-800/80 bg-slate-950/80">
    <div class="mx-auto max-w-6xl px-4 py-8 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm text-slate-300">
        <span class="font-semibold text-slate-100">DBTsearch</span> is powered by
        <a href="https://www.tinytreecounseling.com/" class="ml-1 text-brand underline decoration-1 hover:opacity-90" target="_blank" rel="noopener noreferrer">Tiny Tree Counseling &amp; Consulting</a>
      </p>
      <p class="text-xs text-slate-400">Copyright &copy; {{ "now"|date("Y") }} DBTsearch.org. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
