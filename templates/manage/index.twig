{% if not currentUser %}
  {% redirect url('manage/login') %}
{% endif %}

{% extends '_layouts/site' %}

{% set activeNav = 'manage' %}

{% set previewUsername = currentUser.username ?? currentUser.email ?? 'provider' %}

{# Feature flags — toggle as Craft fields/actions are wired #}
{% set portalFeatures = {
  practiceDetails: false,
  dbtaCertified: true,
  locationDetails: false,
  craftSave: false,
} %}

{# Static mock — mirrors feat/provider-portal-static-availability providerSelfEditMock #}
{% set portalProvider = {
  name: 'Addictions and Stress Clinic dba ASC Psychological Services',
  dbtaCertified: true,
  phone: '(651) 555-0197',
  email: 'contact@asc-psychology.example',
  website: 'https://example.org/asc-psychology',
  locations: [
    {
      id: 'location-self-1',
      name: 'Roseville Office',
      address: '2233 Hamline Ave N',
      city: 'Roseville',
      state: 'MN',
      zip: '55113',
      phone: '(651) 555-0197',
      email: 'contact@asc-psychology.example',
      website: 'https://example.org/asc-psychology',
      availability: true,
    },
    {
      id: 'location-self-2',
      name: 'St. Paul Office',
      address: '875 Arcade St',
      city: 'St. Paul',
      state: 'MN',
      zip: '55106',
      phone: '(651) 555-0142',
      email: 'stpaul@asc-psychology.example',
      website: 'https://example.org/asc-psychology/st-paul',
      availability: false,
    },
    {
      id: 'location-self-3',
      name: 'Minneapolis — Uptown',
      address: '3000 Hennepin Ave S Ste 1',
      city: 'Minneapolis',
      state: 'MN',
      zip: '55408',
      phone: '(612) 555-0177',
      email: 'uptown@asc-psychology.example',
      website: 'https://example.org/asc-psychology/uptown',
      availability: true,
    },
  ],
} %}

{% set pageHeading = portalProvider.name %}
{% set pageSubheading = 'Provider Admin' %}
{% set portalToolbarTitle = portalProvider.locations|length > 1 ? 'Edit your listings' : 'Edit your listing' %}

{% block content %}
  <main class="pb-12">
    <section class="mx-auto max-w-6xl px-4 pt-2 sm:px-6 lg:px-8">
      <div
        id="portal-toolbar"
        class="sticky top-14 z-[1020] -mx-2 mb-6 border-b border-slate-800 bg-slate-950/95 px-2 py-4 backdrop-blur supports-[backdrop-filter]:bg-slate-950/80 sm:mx-0 sm:px-0"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div class="min-w-0 flex-1">
            <h2 class="text-2xl font-semibold text-white">{{ portalToolbarTitle }}</h2>
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <span id="portal-unsaved-badge" class="hidden rounded-md border border-amber-500/40 bg-amber-950/50 px-2 py-0.5 text-xs font-medium text-amber-200">Unsaved changes</span>
              <p id="portal-status-line" class="text-sm text-slate-400"></p>
            </div>
          </div>
          <div id="portal-user-menu" class="relative shrink-0 md:text-right">
            <button
              type="button"
              id="portal-user-menu-trigger"
              class="inline-flex items-center gap-2 rounded-md border border-slate-600 px-3 py-1.5 text-sm text-slate-200 hover:border-slate-500 hover:bg-slate-800/60"
              aria-expanded="false"
              aria-haspopup="menu"
              aria-controls="portal-user-menu-panel"
            >
              <span class="text-slate-400">Logged in as</span>
              <span class="font-medium text-slate-200">{{ previewUsername }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 shrink-0 text-slate-400" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </button>
            <div
              id="portal-user-menu-panel"
              class="absolute right-0 z-10 mt-1 hidden min-w-[9rem] origin-top-right rounded-md border border-slate-600 bg-slate-900 p-1 shadow-lg"
              role="menu"
              aria-labelledby="portal-user-menu-trigger"
              hidden
            >
              <form method="post" role="none">
                {{ csrfInput() }}
                {{ actionInput('users/logout') }}
                {{ redirectInput(url('signed-out')) }}
                <button
                  type="submit"
                  role="menuitem"
                  class="inline-flex w-full items-center gap-2 rounded-md border border-slate-600 px-3 py-1.5 text-left text-sm text-slate-200 hover:border-slate-500 hover:bg-slate-800/60"
                >
                  Logout
                </button>
              </form>
            </div>
          </div>
        </div>

        <div id="portal-save-alert" class="mt-4 hidden scroll-mt-24 rounded-lg border border-emerald-500/40 bg-emerald-950/40 p-4" role="status" aria-live="polite" hidden>
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold text-emerald-100">Saved</p>
              <p class="mt-1 text-sm text-emerald-200/80">
                {% if portalFeatures.craftSave %}
                  Your listing has been updated.
                {% else %}
                  Stored in this browser session only (not synced to the directory yet).
                {% endif %}
              </p>
            </div>
            <button type="button" id="portal-dismiss-save" class="shrink-0 rounded-md px-2 py-1 text-sm text-emerald-200/80 hover:bg-emerald-900/40" aria-label="Dismiss">✕</button>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 md:p-6">
        <form id="portal-form" class="grid gap-6" method="post" action="#" novalidate>
          <div>
            <h3 class="text-xl font-semibold text-white">Provider</h3>
            <div class="mt-4 grid gap-4">
            <div>
              <label for="portal-name" class="mb-2 block text-sm font-medium text-slate-200">Practice / listing name</label>
              <input
                id="portal-name"
                name="name"
                type="text"
                required
                value="{{ portalProvider.name }}"
                class="portal-field w-full rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-white focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </div>

            {% if portalFeatures.dbtaCertified %}
              <div>
                <label for="portal-dbta" class="flex cursor-pointer items-center gap-3 text-sm text-slate-300">
                  <input id="portal-dbta" name="dbtaCertified" type="checkbox" value="1" class="portal-field peer sr-only" {% if portalProvider.dbtaCertified %}checked{% endif %} />
                  {% include '_partials/lightswitch-track' only %}
                  <span class="ms-0.5 leading-snug">DBT-A Certified</span>
                </label>
              </div>
            {% endif %}

            {% if portalFeatures.practiceDetails %}
              <div>
                <button
                  type="button"
                  id="portal-practice-details-toggle"
                  class="rounded-md border border-slate-600 px-3 py-1.5 text-sm font-medium text-slate-200 hover:border-slate-500 hover:bg-slate-800/60"
                  aria-expanded="false"
                  aria-controls="portal-practice-details"
                >
                  Edit details
                </button>
              </div>
              <div id="portal-practice-details" class="hidden grid gap-3 sm:grid-cols-2" hidden>
                <div>
                  <label for="portal-phone" class="mb-2 block text-sm font-medium text-slate-200">Phone</label>
                  <input id="portal-phone" name="phone" type="text" value="{{ portalProvider.phone }}" class="portal-field w-full rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-white focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>
                <div>
                  <label for="portal-email" class="mb-2 block text-sm font-medium text-slate-200">Email</label>
                  <input id="portal-email" name="email" type="email" value="{{ portalProvider.email }}" class="portal-field w-full rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-white focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>
                <div class="sm:col-span-2">
                  <label for="portal-website" class="mb-2 block text-sm font-medium text-slate-200">Website</label>
                  <input id="portal-website" name="website" type="url" value="{{ portalProvider.website }}" class="portal-field w-full rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-white focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
                </div>
              </div>
            {% endif %}
            </div>
          </div>

          <div class="mt-4">
            <h3 class="text-xl font-semibold text-white">Locations</h3>
            <div class="mt-4 grid gap-4 lg:grid-cols-2">
              {% for location in portalProvider.locations %}
                {% include '_manage/location-card' with { location: location, portalFeatures: portalFeatures } only %}
              {% endfor %}
            </div>
          </div>

          <div class="flex flex-wrap gap-3 border-t border-slate-800 pt-4">
            <button
              type="submit"
              id="portal-save-btn"
              disabled
              class="inline-flex items-center rounded-lg bg-slate-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-500 disabled:cursor-not-allowed disabled:opacity-80 disabled:hover:bg-slate-600"
            >
              Save changes
            </button>
          </div>
        </form>
      </div>
    </section>

    <script type="application/json" id="portal-initial-data">{{ portalProvider|json_encode|raw }}</script>
  </main>
{% endblock %}

{% block scripts %}
  <script src="{{ url('/css/manage.min.js') }}" defer></script>
{% endblock %}
