{#
  Splash page — matches frontend/stories/splashPage.js renderImageFlushLeft().
  Content from Splash Single entry if present, else defaults.
  Form: Formie form handle "splashSignup" (create in CP with fields: name, organization, email, provider_listing).
#}
{% set entry = craft.entries.section('splash').one() %}
{% set defaultCopy = "Our single mission is to increase access for those in need of DBT. We're building a directory for anyone to find certified DBT providers in Minnesota and see who has current openings." %}
{% set heading = entry ? (entry.splashHeading ?? entry.title ?? 'Find Available DBT Programs in Minnesota') : (heading ?? 'Find Available DBT Programs in Minnesota') %}
{% set tagline = entry ? (entry.splashTagline ?? 'Coming Soon') : (tagline ?? 'Coming Soon') %}
{% set copy = entry ? (entry.splashCopy ?? defaultCopy) : (copy ?? defaultCopy) %}
{% set formHeading = entry ? (entry.splashFormHeading ?? '✨ Get notified when we launch…') : (formHeading ?? '✨ Get notified when we launch…') %}
{% set submitLabel = entry ? (entry.splashSubmitLabel ?? 'Notify Me') : (submitLabel ?? 'Notify Me') %}
{% set successMessage = entry ? (entry.splashSuccessMessage ?? "You're on the list! We'll notify you when we launch.") : (successMessage ?? "You're on the list! We'll notify you when we launch.") %}
{% set showSuccess = showSuccess ?? (craft.app.request.getParam('signedup') == '1') %}
{% set formHandle = formHandle ?? 'splashSignup' %}
{% set form = craft.formie.forms.handle(formHandle).one() %}
{% set heroImageSrc = url('/images/pexels-steve-1690351.jpg') %}

<!DOCTYPE html>
<html lang="{{ craft.app.language }}" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="referrer" content="origin-when-cross-origin" />
  <title>{{ siteName ?? 'DBT Search' }} — Find Certified DBT Providers in Minnesota</title>
  <link rel="stylesheet" href="{{ url('/css/splash.css') }}" />
  {% if form %}{% do craft.formie.registerAssets(form.handle) %}{% endif %}
</head>
<body class="dark min-h-screen bg-background bg-texture-mesh text-foreground flex flex-col font-sans antialiased" data-theme="dbtsearch">
  <header class="sticky top-0 z-50 w-full border-b border-navbar-line bg-navbar">
    <div class="mx-auto flex max-w-8xl items-center gap-x-4 px-4 py-3 sm:px-6 lg:px-8">
      <a href="{{ url('/') }}" class="flex shrink-0 items-center">
        <img src="{{ url('/images/dbtsearch-logo.svg') }}" alt="DBT Search" class="h-10 w-auto sm:h-16" />
      </a>
    </div>
  </header>

  <div class="relative h-20 w-full shrink-0 md:hidden">
    <img src="{{ heroImageSrc }}" alt="" class="h-full w-full object-cover object-center" />
    <div class="absolute inset-0 bg-background/50" aria-hidden="true"></div>
  </div>

  <main class="flex flex-1 flex-col md:flex-row min-h-0">
    <div class="relative hidden md:block w-1/2 min-w-0 shrink-0 order-2 md:order-1">
      <img src="{{ heroImageSrc }}" alt="" class="absolute inset-0 h-full w-full object-cover" />
      <div class="absolute inset-0 bg-background/40" aria-hidden="true"></div>
    </div>
    <div class="flex flex-1 items-center justify-center px-4 py-6 lg:py-10 sm:px-6 lg:px-8 order-1 md:order-2">
      <div class="w-full max-w-lg space-y-6">
        <div>
        <p class="my-3"><span class="mt-3 inline-flex items-center rounded-full bg-primary/20 px-3 py-1 text-xs border border-primary font-medium text-primary">{{ tagline }}</span></p>
          <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl text-white my-5">{{ heading }}</h1>
          <p class="lg:text-lg text-muted-foreground my-5">{{ copy|raw }}</p>
        </div>
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-foreground mb-8">
          <li class="flex items-center gap-2">
            <svg class="size-5 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>DBT Certified only</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="size-5 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Minnesota</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="size-5 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>Updated regularly</span>
          </li>
        </ul>

        {% if showSuccess %}
          <section id="splash-success" class="mt-5 relative overflow-hidden rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-6" role="alert" aria-live="polite">
            <div class="flex items-start gap-3">
              <svg class="size-5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-sm font-medium text-emerald-200">{{ successMessage }}</p>
            </div>
          </section>
        {% elseif form %}
          {% set submission = form.getCurrentSubmission() %}
          {% set attributes = { method: 'post', class: 'relative text-foreground-muted', 'data-fui-form': form.configJson } %}
          <section class="mt-5 relative overflow-hidden rounded-xl border border-layer-line bg-layer bg-blend-darken p-6">
            <h2 class="text-2xl font-semibold text-accent-300 mb-7">{{ formHeading }}</h2>
            {% set flashError = craft.formie.plugin.service.getFlash(form.id, 'error') %}
            {% if flashError %}<div class="mb-4 text-sm text-red-400" role="alert">{{ flashError|raw }}</div>{% endif %}
            <form {{ attr(attributes) }}>
              {{ actionInput('formie/submissions/submit') }}
              {{ hiddenInput('handle', form.handle) }}
              {{ csrfInput() }}
              {{ redirectInput(url(craft.app.request.pathInfo) ~ '?signedup=1') }}
              {% if submission and submission.id %}{{ hiddenInput('submissionId', submission.id) }}{% endif %}

              {% set fields = form.getFields() %}
              {% if fields|length >= 4 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {% for field in fields[0:2] %}
                    {% set value = attribute(submission, field.handle) ?? field.defaultValue ?? null %}
                    <div>
                      <label for="{{ field.getHtmlId(form) }}" class="splash-label">{{ field.label|t('formie')|raw }}{% if not field.required %} <small class="ml-px"><i>(optional)</i></small>{% endif %}</label>
                      {{ field.getFrontEndInputHtml(form, value)|raw }}
                    </div>
                  {% endfor %}
                </div>
                <div class="mt-4">
                  {% set field = fields[2] %}
                  {% set value = attribute(submission, field.handle) ?? field.defaultValue ?? null %}
                  <label for="{{ field.getHtmlId(form) }}" class="splash-label">{{ field.label|t('formie')|raw }}{% if not field.required %} <small class="ml-px"><i>(optional)</i></small>{% endif %}</label>
                  {{ field.getFrontEndInputHtml(form, value)|raw }}
                </div>
                <div class="pt-2 mt-3">
                  {% set field = fields[3] %}
                  {% set value = attribute(submission, field.handle) ?? field.defaultValue ?? null %}
                  {{ field.getFrontEndInputHtml(form, value)|raw }}
                </div>
              {% else %}
                {% for field in fields %}
                  {% set value = attribute(submission, field.handle) ?? field.defaultValue ?? null %}
                  {{ field.getFrontEndInputHtml(form, value)|raw }}
                {% endfor %}
              {% endif %}

              {% hook 'formie.buttons.before' %}
              <div class="pt-7">
                <button type="submit" data-submit-action="submit" class="flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-4 font-semibold text-primary-foreground hover:opacity-90 focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background focus:outline-none">
                  <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                  <span>{{ submitLabel }}</span>
                </button>
              </div>
            </form>
          </section>
        {% else %}
          {# Fallback when Formie form "splashSignup" not created yet #}
          <section class="mt-5 relative overflow-hidden rounded-xl border border-layer-line bg-layer bg-blend-darken p-6">
            <p class="text-muted-foreground">Create a Formie form with handle <code>splashSignup</code> and fields (in order): name, organization, email, provider_listing (checkbox).</p>
          </section>
        {% endif %}
      </div>
    </div>
  </main>

  {% if showSuccess %}
  <script>document.getElementById('splash-success')?.scrollIntoView({ behavior: 'smooth', block: 'center' });</script>
  {% endif %}

  <footer class="border-t border-border py-6">
    <div class="mx-auto max-w-7xl px-4 pt-5 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm text-muted-foreground">
        <span class="font-semibold text-foreground">DBTsearch</span> is powered by
        <a href="https://www.tinytreecounseling.com/" target="_blank" rel="noopener noreferrer" class="text-primary underline decoration-1 hover:opacity-90">Tiny Tree Counseling &amp; Consulting</a>
      </p>
      <p class="mb-0 text-xs text-muted-foreground">Copyright &copy; {{ "now"|date("Y") }} DBTsearch.org. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
