{#
  Provider directory — Vue app mount. Dev: run `npm run dev` in app/ (port 3000) and load module below, or build assets into web/ and reference production bundle.
#}
<!DOCTYPE html>
<html lang="{{ craft.app.language }}" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title>{{ entry.title }} | {{ siteName ?? 'DBT Search' }}</title>
  <link rel="icon" type="image/x-icon" href="{{ url('favicon.ico') }}" />
  <link rel="stylesheet" href="{{ url('/css/splash.css') }}" />
</head>
<body class="dark min-h-screen bg-background text-foreground flex flex-col font-sans antialiased" data-theme="dbtsearch">
  <header class="sticky top-0 z-50 w-full border-b border-navbar-line bg-navbar">
    <div class="mx-auto flex max-w-8xl items-center gap-x-4 px-4 py-3 sm:px-6 lg:px-8">
      <a href="{{ url('/') }}" class="flex shrink-0 items-center">
        <img src="{{ url('/uploads/dbtsearch-logo.svg') }}" alt="DBT Search" class="h-10 w-auto sm:h-16" />
      </a>
      {% include '_partials/site-nav.twig' %}
    </div>
  </header>

  {% if entry.intro %}
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 text-muted-foreground">
      {{ entry.intro|raw }}
    </div>
  {% endif %}

  <div id="app" class="flex-1 min-h-0"></div>

  {% if craft.app.config.general.devMode %}
    <script type="module" src="http://localhost:3000/src/main.ts"></script>
  {% else %}
    {# TODO: point at Vite build output (e.g. manifest in web/) when wiring production assets #}
  {% endif %}

  <footer class="border-t border-border py-6 mt-auto">
    <div class="mx-auto max-w-7xl px-4 pt-5 text-center sm:px-6 lg:px-8">
      <p class="mb-0 text-xs text-muted-foreground">Copyright &copy; {{ "now"|date("Y") }} DBT Search and dbtsearch.org. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
