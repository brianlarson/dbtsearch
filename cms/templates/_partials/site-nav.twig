  <a href="{{ url('/contact') }}" class="hover:text-foreground{% if craft.app.request.pathInfo == 'contact' %} font-medium text-foreground{% endif %}">Contact</a>
  <a href="{{ url('/providers') }}" class="hover:text-foreground{% if craft.app.request.pathInfo == 'providers' %} font-medium text-foreground{% endif %}">Providers</a>
</nav>
