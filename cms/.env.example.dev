# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# Database — copy to .env for host-side `php craft`. Requires `bootstrap.php` immutable Dotenv (default in this project).
# DDEV web still uses mysql8: container env is set before .env loads, so it overrides these entries.
# mysql8 publishes host port 3306 — see .ddev/docker-compose.mysql.yaml
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=127.0.0.1
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=craft
CRAFT_DB_USER=craft
CRAFT_DB_PASSWORD=craft

# Optional: Resend from local Craft (overrides DDEV Mailpit while set). Remove or empty to use Mailpit again.
# RESEND_API_KEY=re_xxxx
# DDEV Mailpit (default when RESEND_API_KEY is unset): ddev mailpit — optional overrides:
# MAILPIT_SMTP_HOSTNAME=127.0.0.1
# MAILPIT_SMTP_PORT=1025

# General settings
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true
