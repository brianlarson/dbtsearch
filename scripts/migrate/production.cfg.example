# Remote server SSH connection
SSH_HOST=000.000.000.000
SSH_USER=master
SSH_PORT=22
SSH_KEY=~/.ssh/id_rsa

# Remote Craft project root (absolute path on the server)
# e.g. /home/master/applications/[APP_DIR]/public_html
REMOTE_PATH=/home/master/applications/your_app_dir/public_html

# Asset directories to sync (space-separated, relative to project root)
ASSET_DIRS=web/uploads
